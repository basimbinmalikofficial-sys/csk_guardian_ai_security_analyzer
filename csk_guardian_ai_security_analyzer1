class EnhancedFileAnalyzer:
    """Advanced file analyzer with multiple detection methods"""
    
    def __init__(self, ml_engine: MLDetectionEngine, db: DatabaseManager):
        self.ml_engine = ml_engine
        self.db = db
        self.risk_score = 0
        self.findings = []
        self.file_info = {}
    
    def calculate_all_hashes(self, file_path: str) -> Dict[str, str]:
        """Calculate multiple hash types"""
        hashes = {
            'md5': '', 'sha1': '', 'sha256': '', 'sha512': '',
            'ssdeep': '', 'tlsh': ''  # Fuzzy hashes for similarity
        }
        
        try:
            with open(file_path, 'rb') as f:
                data = f.read()
                
                # Standard hashes
                hashes['md5'] = hashlib.md5(data).hexdigest()
                hashes['sha1'] = hashlib.sha1(data).hexdigest()
                hashes['sha256'] = hashlib.sha256(data).hexdigest()
                hashes['sha512'] = hashlib.sha512(data).hexdigest()
                
                # Simple fuzzy hash (simplified ssdeep)
                hashes['ssdeep'] = self.simple_fuzzy_hash(data)
                
        except Exception as e:
            print(f"{getattr(Colors, 'LIGHTRED', '')}[!] Error calculating hashes: {e}{getattr(Colors, 'RESET', '')}")
        
        return hashes
    
    def simple_fuzzy_hash(self, data: bytes) -> str:
        """Simple fuzzy hash for similarity matching"""
        if len(data) < 64:
            return ""
        
        # Take chunks at different positions
        chunks = []
        for i in range(0, min(len(data), 1024), 64):
            chunk = data[i:i+64]
            chunks.append(hashlib.md5(chunk).hexdigest()[:8])
        
        return ':'.join(chunks[:7])  # Return first 7 chunks
    
    def analyze_pe_file(self, file_path: str) -> Dict:
        """Analyze PE (Portable Executable) files"""
        result = {
            'is_pe': False,
            'sections': [],
            'imports': [],
            'exports': [],
            'resources': [],
            'error': None
        }
        
        try:
            # Simple PE detection
            with open(file_path, 'rb') as f:
                header = f.read(2)
                if header != b'MZ':
                    return result
                
                result['is_pe'] = True
                
                # Move to PE header offset
                f.seek(0x3C)
                pe_offset_bytes = f.read(4)
                if len(pe_offset_bytes) == 4:
                    pe_offset = int.from_bytes(pe_offset_bytes, 'little')
                    f.seek(pe_offset)
                    pe_signature = f.read(4)
                    if pe_signature == b'PE\x00\x00':
                        result['valid_pe'] = True
                        
                        # Read section headers (simplified)
                        f.seek(pe_offset + 24)  # Skip to section headers
                        for i in range(5):  # Read first 5 sections
                            section_data = f.read(40)
                            if len(section_data) == 40:
                                section_name = section_data[:8].decode('ascii', errors='ignore').strip('\x00')
                                if section_name:
                                    result['sections'].append(section_name)
                                    
        except Exception as e:
            result['error'] = str(e)
        
        return result
    
    def analyze_office_document(self, file_path: str) -> Dict:
        """Analyze Office documents for macros and exploits"""
        result = {
            'has_macros': False,
            'macros': [],
            'ole_streams': [],
            'error': None
        }
        
        if not OLE_AVAILABLE:
            result['error'] = "olevba not available"
            return result
        
        try:
            vbaparser = olevba.VBA_Parser(file_path)
            if vbaparser.detect_vba_macros():
                result['has_macros'] = True
                
                for (filename, stream_path, vba_filename, vba_code) in vbaparser.extract_macros():
                    result['macros'].append({
                        'filename': filename,
                        'stream': stream_path,
                        'code_length': len(vba_code)
                    })
                    
                    # Check for suspicious macro content
                    if 'AutoOpen' in vba_code or 'Document_Open' in vba_code:
                        result['auto_execute'] = True
                    if 'Shell' in vba_code or 'CreateObject' in vba_code:
                        result['suspicious_commands'] = True
                        
        except Exception as e:
            result['error'] = str(e)
        
        return result
    
    def analyze_image_file(self, file_path: str) -> Dict:
        """Analyze image files for steganography"""
        result = {
            'width': 0,
            'height': 0,
            'format': '',
            'mode': '',
            'has_exif': False,
            'exif_data': {},
            'error': None
        }
        
        if not PIL_AVAILABLE:
            result['error'] = "PIL not available"
            return result
        
        try:
            with Image.open(file_path) as img:
                result['width'], result['height'] = img.size
                result['format'] = img.format
                result['mode'] = img.mode
                
                # Check for EXIF data
                if hasattr(img, '_getexif') and img._getexif():
                    result['has_exif'] = True
                    
        except Exception as e:
            result['error'] = str(e)
        
        return result
    
    def extract_strings(self, file_path: str, min_length: int = 4) -> List[str]:
        """Extract ASCII and Unicode strings from file"""
        strings = []
        
        try:
            with open(file_path, 'rb') as f:
                data = f.read()
                
                # ASCII strings
                ascii_strings = re.findall(b'[\\x20-\\x7E]{' + str(min_length).encode() + b',}', data)
                strings.extend([s.decode('ascii', errors='ignore') for s in ascii_strings])
                
                # Unicode strings (simplified)
                try:
                    unicode_data = data.decode('utf-16le', errors='ignore')
                    unicode_strings = re.findall(r'[\\x20-\\x7E]{' + str(min_length) + ',}', unicode_data)
                    strings.extend(unicode_strings)
                except:
                    pass
                
        except Exception:
            pass
        
        # Remove duplicates and limit
        return list(set(strings))[:100]
    
    def check_against_hash_db(self, file_hash: str) -> Optional[Dict]:
        """Check file hash against known malware database"""
        return self.db.check_threat_indicator('hash', file_hash)
    
    def quarantine_file(self, file_path: str) -> Optional[str]:
        """Move suspicious file to quarantine"""
        try:
            quarantine_path = Path(Config.QUARANTINE_DIR) / f"{datetime.datetime.now():%Y%m%d_%H%M%S}_{os.path.basename(file_path)}"
            os.rename(file_path, quarantine_path)
            return str(quarantine_path)
        except Exception as e:
            print(f"{getattr(Colors, 'LIGHTRED', '')}[!] Error quarantining file: {e}{getattr(Colors, 'RESET', '')}")
            return None
    
    def analyze(self, file_path: str, deep_scan: bool = False, quarantine: bool = False) -> Dict:
        """Main analysis method with enhanced features"""
        print(f"{getattr(Colors, 'LIGHTCYAN', '')}[*] Starting enhanced file analysis: {file_path}{getattr(Colors, 'RESET', '')}")
        
        # Check if file exists
        if not os.path.exists(file_path):
            return {'error': 'File not found'}
        
        # Basic file info
        stat = os.stat(file_path)
        self.file_info = {
            'path': file_path,
            'name': os.path.basename(file_path),
            'size': stat.st_size,
            'extension': os.path.splitext(file_path)[1].lower(),
            'mime_type': get_file_mime_type(file_path),
            'created': datetime.datetime.fromtimestamp(stat.st_ctime).isoformat(),
            'modified': datetime.datetime.fromtimestamp(stat.st_mtime).isoformat(),
            'timestamp': datetime.datetime.now().isoformat()
        }
        
        # Calculate hashes
        print(f"  {getattr(Colors, 'LIGHTYELLOW', '')}▶{getattr(Colors, 'RESET', '')} Calculating file hashes...")
        self.file_info['hashes'] = self.calculate_all_hashes(file_path)
        
        # Check against hash database
        for hash_type, hash_value in self.file_info['hashes'].items():
            if hash_value:
                threat = self.check_against_hash_db(hash_value)
                if threat:
                    self.risk_score += 40
                    self.findings.append(f"File hash matches known {threat['threat_type']}")
        
        # Extract strings for analysis
        if deep_scan:
            print(f"  {getattr(Colors, 'LIGHTYELLOW', '')}▶{getattr(Colors, 'RESET', '')} Extracting strings...")
            self.file_info['strings'] = self.extract_strings(file_path)
            self.file_info['suspicious_strings'] = [
                s for s in self.file_info['strings']
                if any(pattern in s.lower() for pattern in Config.SUSPICIOUS_STRINGS)
            ]
        
        # Run parallel analysis based on file type
        with ThreadPoolExecutor(max_workers=4) as executor:
            futures = {}
            
            # PE analysis
            if self.file_info['extension'] in ['.exe', '.dll', '.sys', '.ocx']:
                futures['pe'] = executor.submit(self.analyze_pe_file, file_path)
            
            # Office document analysis
            if self.file_info['extension'] in ['.doc', '.docx', '.xls', '.xlsx', '.ppt', '.pptx']:
                futures['office'] = executor.submit(self.analyze_office_document, file_path)
            
            # Image analysis
            if self.file_info['extension'] in ['.jpg', '.jpeg', '.png', '.gif', '.bmp']:
                futures['image'] = executor.submit(self.analyze_image_file, file_path)
            
            # ML analysis
            futures['ml'] = executor.submit(self.ml_engine.classify_file, self.file_info)
            
            # Collect results
            for name, future in futures.items():
                try:
                    result = future.result(timeout=Config.TIMEOUT)
                    self.file_info[name] = result
                    print(f"  {getattr(Colors, 'LIGHTGREEN', '')}✓{getattr(Colors, 'RESET', '')} {name.upper()} analysis complete")
                except Exception as e:
                    print(f"  {getattr(Colors, 'LIGHTRED', '')}✗{getattr(Colors, 'RESET', '')} {name.upper()} failed: {e}")
        
        # Entropy analysis
        print(f"  {getattr(Colors, 'LIGHTYELLOW', '')}▶{getattr(Colors, 'RESET', '')} Performing entropy analysis...")
        try:
            with open(file_path, 'rb') as f:
                data = f.read(10240)  # First 10KB
                self.file_info['entropy'] = calculate_entropy(data)
        except:
            self.file_info['entropy'] = 0
        
        # Calculate risk score
        self.calculate_enhanced_risk_score()
        
        # Quarantine if requested and high risk
        if quarantine and self.risk_score > Config.MEDIUM_RISK_THRESHOLD:
            quarantine_path = self.quarantine_file(file_path)
            if quarantine_path:
                self.file_info['quarantined'] = quarantine_path
        
        return self.get_results()
    
    def calculate_enhanced_risk_score(self) -> int:
        """Calculate enhanced risk score"""
        score = 0
        findings = []
        
        # ML score
        if 'ml' in self.file_info:
            ml_score = self.file_info['ml'].get('score', 0)
            score += ml_score * 0.4
            findings.extend(self.file_info['ml'].get('reasons', []))
        
        # File size anomalies
        if self.file_info['size'] > 100 * 1024 * 1024:  # > 100MB
            score += 15
            findings.append("Very large file size")
        
        # Suspicious extension
        dangerous_exts = ['.exe', '.bat', '.cmd', '.ps1', '.vbs', '.js', '.jar']
        if self.file_info['extension'] in dangerous_exts:
            score += 20
            findings.append(f"Dangerous file extension: {self.file_info['extension']}")
        
        # PE analysis findings
        if 'pe' in self.file_info:
            pe = self.file_info['pe']
            if pe.get('sections'):
                suspicious_sections = [s for s in pe['sections'] if s in ['.UPX', '.packed']]
                if suspicious_sections:
                    score += 25
                    findings.append(f"Packed/obfuscated sections: {', '.join(suspicious_sections)}")
        
        # Office document findings
        if 'office' in self.file_info:
            office = self.file_info['office']
            if office.get('has_macros'):
                score += 30
                findings.append("Contains macros")
            if office.get('auto_execute'):
                score += 20
                findings.append("Auto-executing macros detected")
        
        # Suspicious strings
        if self.file_info.get('suspicious_strings'):
            s_count = len(self.file_info['suspicious_strings'])
            score += min(30, s_count * 2)
            findings.append(f"Contains {s_count} suspicious strings")
        
        # High entropy
        if self.file_info.get('entropy', 0) > 7.5:
            score += 25
            findings.append("Very high entropy - likely encrypted/packed")
        elif self.file_info.get('entropy', 0) > 6.5:
            score += 15
            findings.append("High entropy - possible obfuscation")
        
        self.risk_score = min(score, Config.MAX_RISK_SCORE)
        self.findings = findings
        
        return self.risk_score
    
    def get_results(self) -> Dict:
        """Return comprehensive results"""
        return {
            'file_info': self.file_info,
            'risk_score': self.risk_score,
            'risk_level': self.get_risk_level(),
            'findings': self.findings,
            'color': get_risk_color(self.risk_score)
        }
    
    def get_risk_level(self) -> str:
        """Get risk level based on score"""
        if self.risk_score <= Config.LOW_RISK_THRESHOLD:
            return "SAFE"
        elif self.risk_score <= Config.MEDIUM_RISK_THRESHOLD:
            return "SUSPICIOUS"
        else:
            return "DANGEROUS"
    
