class EnhancedURLAnalyzer:
    """Advanced URL analyzer with multiple data sources"""
    
    def __init__(self, ml_engine: MLDetectionEngine, db: DatabaseManager):
        self.ml_engine = ml_engine
        self.db = db
        self.session = create_session_with_retries() if REQUESTS_AVAILABLE else None
        self.risk_score = 0
