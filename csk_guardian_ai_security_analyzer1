            (r'password.*reset', 10, "Password reset page"),
            (r'bank.*online', 15, "Banking-related URL"),
            (r'paypal.*secure', 15, "PayPal impersonation"),
            (r'apple.*id.*sign', 15, "Apple ID phishing"),
            (r'microsoft.*account', 15, "Microsoft account phishing"),
        ]
        
        for pattern, score, reason in phishing_patterns:
            if re.search(pattern, url.lower()):
                risk_score += score
                reasons.append(reason)
        
        # Check content for phishing indicators
        if content:
            # Check for password fields
            if 'password' in content.lower() and 'input' in content.lower():
                risk_score += 5
                reasons.append("Contains password input field")
            
            # Check for fake login forms
            if 'login' in content.lower() and 'form' in content.lower():
                risk_score += 5
                reasons.append("Contains login form")
        
        return min(risk_score, 100), reasons
    
    def classify_url(self, url: str) -> Dict:
        """Classify URL using ML models"""
        features = self.extract_url_features(url)
        ml_score, ml_reasons = self.models['url_classifier'](features)
        phishing_score, phishing_reasons = self.phishing_detector(url)
        
        # Combine scores
        total_score = (ml_score * 0.6 + phishing_score * 0.4)
        all_reasons = ml_reasons + phishing_reasons
        
        return {
            'score': total_score,
            'reasons': all_reasons,
            'features': features
        }
    
    def classify_file(self, file_info: Dict) -> Dict:
        """Classify file using ML models"""
        features = {
            'size': file_info.get('size', 0),
            'extension': file_info.get('extension', ''),
            'entropy': file_info.get('entropy', 0),
            'suspicious_strings': file_info.get('suspicious_strings', [])
        }
        
        score, reasons = self.models['file_classifier'](features)
        
        return {
            'score': score,
            'reasons': reasons,
            'features': features
        }

