if FLASK_AVAILABLE:
    class WebAPIServer:
        """Flask-based web API server"""
        
        def __init__(self, app_instance):
            self.app = Flask(__name__)
            self.csk_app = app_instance
            self.setup_routes()
        
        def setup_routes(self):
            """Setup API routes"""
            
            @self.app.route('/')
            def home():
                return jsonify({
                    'name': 'CSK Guardian v2.0 API',
                    'status': 'online',
                    'version': '2.0',
                    'endpoints': [
                        '/api/scan/url',
                        '/api/scan/file',
                        '/api/history',
                        '/api/stats',
                        '/api/health'
                    ]
                })
            
            @self.app.route('/api/health')
            def health():
                return jsonify({
                    'status': 'healthy',
                    'timestamp': datetime.datetime.now().isoformat()
                })
            
            @self.app.route('/api/scan/url', methods=['POST'])
            def scan_url():
                data = request.get_json()
                url = data.get('url', '') if data else ''
                
                if not url:
                    return jsonify({'error': 'No URL provided'}), 400
                
                # Perform scan
                results = self.csk_app.enhanced_url_analyzer.analyze(url)
                
                # Save to database
                scan_data = {
                    'type': 'URL',
                    'target': url,
                    'risk_score': results['risk_score'],
                    'risk_level': results['risk_level'],
                    'details': results
                }
                self.csk_app.db.save_scan(scan_data)
                
                return jsonify(results)
            
            @self.app.route('/api/history')
            def get_history():
                limit = request.args.get('limit', 50, type=int)
                history = self.csk_app.db.get_recent_scans(limit)
                return jsonify({'history': history})
            
            @self.app.route('/api/stats')
            def get_stats():
                conn = sqlite3.connect(Config.DATABASE_FILE)
                cursor = conn.cursor()
                
                # Get total scans
                cursor.execute("SELECT COUNT(*) FROM scans")
                total_scans = cursor.fetchone()[0]
                
                # Get risk distribution
                cursor.execute("""
                    SELECT risk_level, COUNT(*) 
                    FROM scans 
                    GROUP BY risk_level
                """)
                risk_dist = dict(cursor.fetchall())
                
                conn.close()
                
                return jsonify({
                    'total_scans': total_scans,
                    'risk_distribution': risk_dist,
                    'timestamp': datetime.datetime.now().isoformat()
                })
        
        def run(self, host='127.0.0.1', port=5000, debug=False):
            """Run the web server"""
            print(f"{getattr(Colors, 'LIGHTGREEN', '')}[✓] Starting web API server on http://{host}:{port}{getattr(Colors, 'RESET', '')}")
            self.app.run(host=host, port=port, debug=debug)

