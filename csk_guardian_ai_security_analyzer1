    def calculate_enhanced_risk_score(self) -> int:
        """Calculate enhanced risk score using multiple factors"""
        score = 0
        findings = []
        
        # ML score
        if 'ml' in self.url_info:
            ml_score = self.url_info['ml'].get('score', 0)
            score += ml_score * 0.3
            findings.extend(self.url_info['ml'].get('reasons', []))
        
        # VirusTotal results
        if 'vt' in self.url_info and 'malicious' in self.url_info['vt']:
            vt = self.url_info['vt']
            if vt.get('malicious', 0) > 0:
                score += min(40, vt['malicious'] * 5)
                findings.append(f"Flagged by {vt['malicious']} VirusTotal engines")
        
        # AbuseIPDB results
        if 'abuseip' in self.url_info and 'abuse_confidence' in self.url_info['abuseip']:
            abuse_score = self.url_info['abuseip']['abuse_confidence']
            if abuse_score > 50:
                score += abuse_score * 0.3
                findings.append(f"AbuseIPDB confidence: {abuse_score}%")
        
        # DNS anomalies
        dns_info = self.url_info.get('dns', {})
        if dns_info.get('error'):
            score += 25
            findings.append(f"DNS error: {dns_info['error']}")
        
        # Web content analysis
        content = self.url_info.get('content', {})
        if content.get('forms'):
            score += len(content['forms']) * 5
            findings.append(f"Contains {len(content['forms'])} forms")
        
        if content.get('iframes'):
            score += len(content['iframes']) * 10
            findings.append(f"Contains {len(content['iframes'])} iframes")
        
        # SSL issues
        ssl_info = self.url_info.get('ssl', {})
        if ssl_info.get('error'):
            score += 30
            findings.append(f"SSL error: {ssl_info['error']}")
        
        self.risk_score = min(score, Config.MAX_RISK_SCORE)
        self.findings = findings
        
        return self.risk_score
    
    def get_results(self) -> Dict:
        """Return comprehensive results"""
        return {
            'url_info': self.url_info,
            'risk_score': self.risk_score,
            'risk_level': self.get_risk_level(),
