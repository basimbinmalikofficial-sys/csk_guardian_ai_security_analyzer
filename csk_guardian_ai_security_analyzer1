class RealtimeMonitor:
    """Real-time file system monitor for threat detection"""
    
    def __init__(self, analyzer: EnhancedFileAnalyzer):
        self.analyzer = analyzer
        self.running = False
        self.monitored_paths = []
        self.alert_callbacks = []
    
    def add_path(self, path: str):
        """Add path to monitor"""
        if os.path.exists(path):
            self.monitored_paths.append(path)
            print(f"{getattr(Colors, 'LIGHTGREEN', '')}[✓] Now monitoring: {path}{getattr(Colors, 'RESET', '')}")
    
    def on_alert(self, callback):
        """Register alert callback"""
        self.alert_callbacks.append(callback)
    
    def scan_directory(self, path: str, recursive: bool = True):
        """Scan directory for threats"""
        threats = []
        path_obj = Path(path)
        
        if path_obj.is_file():
            # Single file
            result = self.analyzer.analyze(str(path_obj))
            if result['risk_score'] > Config.MEDIUM_RISK_THRESHOLD:
                threats.append(result)
                self.trigger_alert(result)
        
        elif path_obj.is_dir():
            # Directory
            pattern = "**/*" if recursive else "*"
            files = list(path_obj.glob(pattern))
            
            for i, file_path in enumerate(files):
                if file_path.is_file():
                    print_progress(i+1, len(files), prefix='Scanning:', suffix=str(file_path))
                    result = self.analyzer.analyze(str(file_path))
                    if result['risk_score'] > Config.MEDIUM_RISK_THRESHOLD:
                        threats.append(result)
                        self.trigger_alert(result)
        
        return threats
    
    def trigger_alert(self, threat_info: Dict):
        """Trigger alert for detected threat"""
        alert_msg = f"""
{getattr(Colors, 'LIGHTRED', '')}╔══════════════════════════════════════════════════════════╗
║                    THREAT DETECTED!                      ║
╠══════════════════════════════════════════════════════════╣
║ File: {threat_info['file_info']['name'][:40]:<40} ║
║ Risk Score: {threat_info['risk_score']:.1f}/100                         ║
║ Risk Level: {threat_info['risk_level']:<12}                  ║
╚══════════════════════════════════════════════════════════╝{getattr(Colors, 'RESET', '')}
        """
        print(alert_msg)
        
        for callback in self.alert_callbacks:
            try:
                callback(threat_info)
            except:
                pass
    
    def start_monitoring(self, interval: int = 60):
        """Start real-time monitoring"""
        self.running = True
        print(f"{getattr(Colors, 'LIGHTCYAN', '')}[*] Starting real-time monitor (interval: {interval}s){getattr(Colors, 'RESET', '')}")
        
        while self.running:
            for path in self.monitored_paths:
                threats = self.scan_directory(path)
                if threats:
                    print(f"{getattr(Colors, 'LIGHTYELLOW', '')}[!] Found {len(threats)} threats in {path}{getattr(Colors, 'RESET', '')}")
            
            # Sleep in intervals to allow for KeyboardInterrupt
            for _ in range(interval):
                if not self.running:
                    break
                time.sleep(1)
    
    def stop_monitoring(self):
        """Stop real-time monitoring"""
        self.running = False
        print(f"{getattr(Colors, 'LIGHTYELLOW', '')}[!] Monitor stopped{getattr(Colors, 'RESET', '')}")

