class MLDetectionEngine:
    """Machine Learning based detection engine"""
    
    def __init__(self):
        self.models = {}
        self.feature_extractors = {}
        self.load_models()
    
    def load_models(self):
        """Load pre-trained models (simulated for demo)"""
        # In production, load actual ML models here
        self.models['url_classifier'] = self.rule_based_url_classifier
        self.models['file_classifier'] = self.rule_based_file_classifier
        self.models['phishing_detector'] = self.phishing_detector
    
    def extract_url_features(self, url: str) -> Dict:
        """Extract features from URL for ML analysis"""
        features = {}
        parsed = urlparse(url)
        domain = parsed.netloc
        
        # Length features
        features['url_length'] = len(url)
        features['domain_length'] = len(domain)
        features['path_length'] = len(parsed.path)
        
        # Character features
        features['digit_count'] = sum(c.isdigit() for c in url)
        features['special_char_count'] = sum(not c.isalnum() for c in url)
        features['subdomain_count'] = len(domain.split('.')) - 2 if len(domain.split('.')) > 2 else 0
        
        # Entropy features
        features['domain_entropy'] = calculate_entropy(domain)
        features['path_entropy'] = calculate_entropy(parsed.path)
        
        # Suspicious patterns
        features['has_ip'] = 1 if self.check_ip_in_domain(domain) else 0
        features['is_shortened'] = 1 if any(s in domain for s in Config.URL_SHORTENERS) else 0
        features['suspicious_tld'] = 1 if any(domain.endswith(tld) for tld in Config.SUSPICIOUS_TLDS) else 0
        
        return features
    
    def check_ip_in_domain(self, domain: str) -> bool:
        """Check if domain is IP address"""
        try:
            ipaddress.ip_address(domain)
            return True
        except ValueError:
            return False
    
    def rule_based_url_classifier(self, features: Dict) -> Tuple[float, List[str]]:
        """Rule-based URL classification (simulated ML)"""
        risk_score = 0
        reasons = []
        
        # Weighted scoring based on features
        weights = {
            'url_length': (0.1, 200),  # (weight, threshold)
            'special_char_count': (0.5, 20),
            'subdomain_count': (2.0, 3),
            'domain_entropy': (5.0, 4.5),
            'has_ip': (15.0, 1),
            'is_shortened': (10.0, 1),
            'suspicious_tld': (8.0, 1)
        }
        
        for feature, (weight, threshold) in weights.items():
            if feature in features:
                if isinstance(threshold, int) and features[feature] > threshold:
                    risk_score += weight * (features[feature] / threshold)
                    reasons.append(f"High {feature}: {features[feature]}")
                elif isinstance(threshold, float) and features[feature] > threshold:
                    risk_score += weight
                    reasons.append(f"Suspicious {feature}: {features[feature]:.2f}")
        
        return min(risk_score, 100), reasons
    
    def rule_based_file_classifier(self, features: Dict) -> Tuple[float, List[str]]:
        """Rule-based file classification"""
        risk_score = 0
        reasons = []
        
        # File size anomaly
        if features.get('size', 0) > 50 * 1024 * 1024:  # 50MB
            risk_score += 10
            reasons.append("Large file size")
        
        # Executable extensions
        executable_exts = ['.exe', '.bat', '.cmd', '.ps1', '.vbs', '.js', '.jar']
        if features.get('extension') in executable_exts:
            risk_score += 20
            reasons.append("Executable file type")
        
        # High entropy (obfuscation)
        if features.get('entropy', 0) > 7.0:
            risk_score += 25
            reasons.append("High entropy - possible obfuscation")
        elif features.get('entropy', 0) > 6.0:
            risk_score += 10
            reasons.append("Moderate entropy")
        
        # Suspicious strings
        suspicious_count = len(features.get('suspicious_strings', []))
        if suspicious_count > 0:
            risk_score += min(30, suspicious_count * 5)
            reasons.append(f"Contains {suspicious_count} suspicious strings")
        
        return min(risk_score, 100), reasons
    
