class DatabaseManager:
    """SQLite database manager for persistent storage"""
    
    def __init__(self, db_path: str = Config.DATABASE_FILE):
        self.db_path = db_path
        self.init_database()
    
    def init_database(self):
        """Initialize database tables"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Scans table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS scans (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                scan_type TEXT NOT NULL,
                target TEXT NOT NULL,
                risk_score INTEGER,
                risk_level TEXT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
                details TEXT,
                report_path TEXT
            )
        ''')
        
        # Threat intelligence table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS threat_intel (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                indicator_type TEXT NOT NULL,
                indicator_value TEXT NOT NULL,
                threat_type TEXT,
                confidence INTEGER,
                first_seen DATETIME,
                last_seen DATETIME,
                source TEXT,
                UNIQUE(indicator_type, indicator_value)
            )
        ''')
        
        # File signatures table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS file_signatures (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                hash_type TEXT NOT NULL,
                hash_value TEXT NOT NULL,
                file_name TEXT,
                threat_name TEXT,
                detection_count INTEGER DEFAULT 1,
                first_seen DATETIME,
                last_seen DATETIME,
                UNIQUE(hash_type, hash_value)
            )
        ''')
        
        # URL reputation table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS url_reputation (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                domain TEXT NOT NULL UNIQUE,
                ip_address TEXT,
                reputation_score INTEGER,
                categories TEXT,
                last_checked DATETIME
            )
        ''')
        
        # Settings table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS settings (
                key TEXT PRIMARY KEY,
                value TEXT,
                updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        conn.commit()
        conn.close()
    
    def save_scan(self, scan_data: Dict) -> int:
        """Save scan result to database"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('''
            INSERT INTO scans (scan_type, target, risk_score, risk_level, details)
            VALUES (?, ?, ?, ?, ?)
        ''', (
            scan_data.get('type', 'Unknown'),
            scan_data.get('target', ''),
            scan_data.get('risk_score', 0),
            scan_data.get('risk_level', 'Unknown'),
            json.dumps(scan_data.get('details', {}))
        ))
        
        scan_id = cursor.lastrowid
        conn.commit()
        conn.close()
        return scan_id
    
    def get_recent_scans(self, limit: int = 50) -> List[Dict]:
        """Get recent scans"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('''
            SELECT id, scan_type, target, risk_score, risk_level, timestamp
            FROM scans
            ORDER BY timestamp DESC
            LIMIT ?
        ''', (limit,))
        
        rows = cursor.fetchall()
        conn.close()
        
        return [
            {
                'id': row[0],
                'type': row[1],
                'target': row[2],
                'risk_score': row[3],
                'risk_level': row[4],
                'timestamp': row[5]
            }
            for row in rows
        ]
    
    def add_threat_indicator(self, indicator: Dict):
        """Add threat indicator to database"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('''
            INSERT OR REPLACE INTO threat_intel
            (indicator_type, indicator_value, threat_type, confidence, last_seen, source)
            VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP, ?)
        ''', (
            indicator.get('type'),
            indicator.get('value'),
            indicator.get('threat_type'),
            indicator.get('confidence', 50),
            indicator.get('source', 'local')
        ))
        
        conn.commit()
        conn.close()
    
    def check_threat_indicator(self, indicator_type: str, indicator_value: str) -> Optional[Dict]:
        """Check if indicator exists in threat database"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('''
            SELECT threat_type, confidence, source, last_seen
            FROM threat_intel
            WHERE indicator_type = ? AND indicator_value = ?
        ''', (indicator_type, indicator_value))
        
        row = cursor.fetchone()
        conn.close()
        
        if row:
            return {
                'threat_type': row[0],
                'confidence': row[1],
                'source': row[2],
                'last_seen': row[3]
            }
        return None

