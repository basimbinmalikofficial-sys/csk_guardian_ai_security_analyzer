    def advanced_dns_lookup(self, domain: str) -> Dict:
        """Perform comprehensive DNS lookup"""
        result = {
            'a_records': [],
            'mx_records': [],
            'ns_records': [],
            'txt_records': [],
            'cname': None,
            'error': None
        }
        
        if not DNS_AVAILABLE:
            # Fallback to socket
            try:
                ips = socket.gethostbyname_ex(domain)
                result['a_records'] = ips[2]
            except Exception as e:
                result['error'] = str(e)
            return result
        
        try:
            # A records
            try:
                answers = dns.resolver.resolve(domain, 'A')
                result['a_records'] = [str(r) for r in answers]
            except:
                pass
            
            # MX records
            try:
                answers = dns.resolver.resolve(domain, 'MX')
                result['mx_records'] = [str(r.exchange) for r in answers]
            except:
                pass
            
            # NS records
            try:
                answers = dns.resolver.resolve(domain, 'NS')
                result['ns_records'] = [str(r) for r in answers]
            except:
                pass
            
            # TXT records
            try:
                answers = dns.resolver.resolve(domain, 'TXT')
                result['txt_records'] = [str(r) for r in answers]
            except:
                pass
            
            # CNAME
            try:
                answers = dns.resolver.resolve(domain, 'CNAME')
                result['cname'] = str(answers[0].target)
            except:
                pass
                
        except Exception as e:
            result['error'] = str(e)
        
        return result
    
    def check_ssl_advanced(self, domain: str) -> Dict:
        """Advanced SSL certificate analysis"""
        result = {
            'valid': False,
            'issuer': None,
            'subject': None,
            'version': None,
            'serial_number': None,
            'not_before': None,
            'not_after': None,
            'san': [],
            'error': None
        }
        
        if not SSL_AVAILABLE:
            result['error'] = "SSL module not available"
            return result
        
        try:
            context = ssl.create_default_context()
            with socket.create_connection((domain, 443), timeout=Config.TIMEOUT) as sock:
                with context.wrap_socket(sock, server_hostname=domain) as ssock:
                    cert = ssock.getpeercert()
                    
                    result['valid'] = True
                    result['issuer'] = dict(x[0] for x in cert['issuer'])
                    result['subject'] = dict(x[0] for x in cert['subject'])
                    result['version'] = cert.get('version')
                    result['serial_number'] = cert.get('serialNumber')
                    result['not_before'] = cert.get('notBefore')
                    result['not_after'] = cert.get('notAfter')
                    result['san'] = [san[1] for san in cert.get('subjectAltName', [])]
                    
        except Exception as e:
            result['error'] = str(e)
        
        return result
    
    def analyze_web_content(self, url: str) -> Dict:
        """Analyze web page content"""
        result = {
            'title': None,
            'forms': [],
            'scripts': [],
            'iframes': [],
            'redirects': [],
            'error': None
        }
        
        if not self.session:
            result['error'] = "Requests not available"
            return result
        
        try:
            response = self.session.get(url, timeout=Config.TIMEOUT, allow_redirects=True)
            
            # Track redirects
            if response.history:
                result['redirects'] = [r.url for r in response.history]
            
            if BEAUTIFULSOUP_AVAILABLE and response.text:
                soup = BeautifulSoup(response.text, 'html.parser')
                
                # Get title
                if soup.title:
                    result['title'] = soup.title.string
                
                # Find forms
                for form in soup.find_all('form'):
                    form_info = {
                        'action': form.get('action', ''),
                        'method': form.get('method', 'get'),
                        'inputs': []
                    }
                    for input_tag in form.find_all('input'):
                        form_info['inputs'].append({
                            'type': input_tag.get('type', 'text'),
                            'name': input_tag.get('name', '')
                        })
                    result['forms'].append(form_info)
                
                # Find scripts
                for script in soup.find_all('script'):
                    if script.get('src'):
                        result['scripts'].append(script['src'])
                
                # Find iframes
                for iframe in soup.find_all('iframe'):
                    result['iframes'].append(iframe.get('src', ''))
                    
        except Exception as e:
            result['error'] = str(e)
        
        return result
    
    def analyze(self, url: str, deep_scan: bool = False) -> Dict:
        """Main analysis method with enhanced features"""
        print(f"{getattr(Colors, 'LIGHTCYAN', '')}[*] Starting enhanced analysis for: {url}{getattr(Colors, 'RESET', '')}")
        
        # Normalize URL
        if not url.startswith(('http://', 'https://')):
            url = 'http://' + url
        
        domain = urlparse(url).netloc
        
        self.url_info = {
            'url': url,
            'domain': domain,
            'timestamp': datetime.datetime.now().isoformat()
        }
        
        # Run all checks in parallel
        with ThreadPoolExecutor(max_workers=Config.MAX_THREADS) as executor:
