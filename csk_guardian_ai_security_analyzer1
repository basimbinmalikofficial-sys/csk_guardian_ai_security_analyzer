# ============================================================================
# ENHANCED COMMAND LINE INTERFACE
# ============================================================================

def enhanced_main():
    """Enhanced command line entry point"""
    parser = argparse.ArgumentParser(description='CSK Guardian v2.0 - Enhanced AI-Powered Security Analyzer')
    
    # Basic options
    parser.add_argument('--url', '-u', help='Scan a single URL')
    parser.add_argument('--file', '-f', help='Scan a single file')
    parser.add_argument('--deep', '-d', action='store_true', help='Perform deep scan')
    parser.add_argument('--batch', '-b', help='Batch scan from file')
    parser.add_argument('--type', '-t', choices=['url', 'file'], default='url', help='Batch scan type')
    
    # Output options
    parser.add_argument('--report', '-r', action='store_true', help='Generate HTML report')
    parser.add_argument('--output', '-o', help='Output file for results')
    parser.add_argument('--format', '-F', choices=['json', 'csv', 'html'], default='json', help='Output format')
    
    # API options
    parser.add_argument('--api', action='store_true', help='Start API server')
    parser.add_argument('--host', default='127.0.0.1', help='API server host')
    parser.add_argument('--port', type=int, default=5000, help='API server port')
    
    # Monitor options
    parser.add_argument('--monitor', '-m', help='Monitor directory for threats')
    parser.add_argument('--interval', type=int, default=60, help='Monitor interval (seconds)')
    
    # Database options
    parser.add_argument('--history', '-H', action='store_true', help='View scan history')
    parser.add_argument('--stats', '-s', action='store_true', help='Show statistics')
    parser.add_argument('--clear-history', action='store_true', help='Clear scan history')
    
    # Configuration
    parser.add_argument('--config', help='Configuration file path')
    parser.add_argument('--verbose', '-v', action='store_true', help='Verbose output')
    
    args = parser.parse_args()
    
    # Create application instance
    app = EnhancedCSKGuardian()
    
    # Load config if specified
    if args.config and os.path.exists(args.config):
        try:
            with open(args.config, 'r') as f:
                config = json.load(f)
                # Update API keys
                Config.VIRUSTOTAL_API_KEY = config.get('virustotal_api_key', Config.VIRUSTOTAL_API_KEY)
                Config.ABUSEIPDB_API_KEY = config.get('abuseipdb_api_key', Config.ABUSEIPDB_API_KEY)
                Config.URLSCAN_API_KEY = config.get('urlscan_api_key', Config.URLSCAN_API_KEY)
        except:
            pass
    
    # Handle commands
    if args.clear_history:
        app.history_manager.clear_history()
        conn = sqlite3.connect(Config.DATABASE_FILE)
        cursor = conn.cursor()
        cursor.execute("DELETE FROM scans")
        conn.commit()
        conn.close()
        print(f"{getattr(Colors, 'GREEN', '')}[✓] History cleared{getattr(Colors, 'RESET', '')}")
        return
    
    if args.stats:
        conn = sqlite3.connect(Config.DATABASE_FILE)
        cursor = conn.cursor()
        
        cursor.execute("SELECT COUNT(*) FROM scans")
        total_scans = cursor.fetchone()[0]
        
        cursor.execute("SELECT risk_level, COUNT(*) FROM scans GROUP BY risk_level")
        risk_dist = dict(cursor.fetchall())
        
        cursor.execute("SELECT scan_type, COUNT(*) FROM scans GROUP BY scan_type")
        type_dist = dict(cursor.fetchall())
        
        conn.close()
        
        print(f"\n{getattr(Colors, 'BOLD', '')}CSK Guardian Statistics{getattr(Colors, 'RESET', '')}")
        print(f"{'='*50}")
        print(f"Total Scans: {total_scans}")
        print(f"\nBy Risk Level:")
        for level, count in risk_dist.items():
            color = get_risk_color(0)  # Just for color name
            print(f"  {level}: {count}")
        print(f"\nBy Type:")
        for stype, count in type_dist.items():
            print(f"  {stype}: {count}")
        return
    
    if args.api:
        if app.api_server:
            print(f"{getattr(Colors, 'GREEN', '')}[✓] Starting API server on {args.host}:{args.port}{getattr(Colors, 'RESET', '')}")
            app.api_server.run(host=args.host, port=args.port)
        else:
            print(f"{getattr(Colors, 'RED', '')}[!] Flask not installed. Install with: pip install flask{getattr(Colors, 'RESET', '')}")
        return
    
    if args.monitor:
        app.monitor.add_path(args.monitor)
        try:
            app.monitor.start_monitoring(args.interval)
        except KeyboardInterrupt:
            app.monitor.stop_monitoring()
        return
    
    if args.batch:
        if not os.path.exists(args.batch):
            print(f"{getattr(Colors, 'RED', '')}[!] Batch file not found: {args.batch}{getattr(Colors, 'RESET', '')}")
            return
        
        with open(args.batch, 'r') as f:
            targets = [line.strip() for line in f if line.strip()]
        
        print(f"{getattr(Colors, 'CYAN', '')}[*] Batch scanning {len(targets)} targets{getattr(Colors, 'RESET', '')}")
        
        results = []
        for target in targets:
            if args.type == 'url':
                result = app.enhanced_url_analyzer.analyze(target)
            else:
                result = app.enhanced_file_analyzer.analyze(target)
            
            results.append({
                'target': target,
                'risk_score': result['risk_score'],
                'risk_level': result['risk_level'],
                'findings': result['findings'][:3]
            })
        
        # Output results
        if args.output:
            with open(args.output, 'w') as f:
                if args.format == 'json':
                    json.dump(results, f, indent=2)
                elif args.format == 'csv':
                    import csv
                    writer = csv.DictWriter(f, fieldnames=['target', 'risk_score', 'risk_level', 'findings'])
                    writer.writeheader()
                    writer.writerows(results)
            
            print(f"{getattr(Colors, 'GREEN', '')}[✓] Results saved to: {args.output}{getattr(Colors, 'RESET', '')}")
        else:
            print(json.dumps(results, indent=2))
        
        return
    
    if args.url:
        display_banner()
        if args.deep:
            print(f"{getattr(Colors, 'YELLOW', '')}[!] Deep scan mode enabled{getattr(Colors, 'RESET', '')}")
        
        results = app.enhanced_url_analyzer.analyze(args.url)
        app.enhanced_url_analyzer.display_results()
        
        # Save to database
        scan_data = {
            'type': 'URL',
            'target': args.url,
            'risk_score': results['risk_score'],
            'risk_level': results['risk_level'],
            'details': results
        }
        app.db.save_scan(scan_data)
        
        # Generate report if requested
        if args.report:
            report_path = app.report_generator.generate_url_report(results)
            if report_path:
                print(f"{getattr(Colors, 'GREEN', '')}[✓] Report saved to: {report_path}{getattr(Colors, 'RESET', '')}")
        
        # Save output if requested
        if args.output:
            with open(args.output, 'w') as f:
                json.dump(results, f, indent=2)
            print(f"{getattr(Colors, 'GREEN', '')}[✓] Results saved to: {args.output}{getattr(Colors, 'RESET', '')}")
        
        return
    
    if args.file:
        display_banner()
        if args.deep:
            print(f"{getattr(Colors, 'YELLOW', '')}[!] Deep scan mode enabled{getattr(Colors, 'RESET', '')}")
        
        results = app.enhanced_file_analyzer.analyze(args.file, deep_scan=args.deep)
        
        if 'error' not in results:
            app.enhanced_file_analyzer.display_results()
            
            # Save to database
            scan_data = {
                'type': 'File',
                'target': args.file,
                'risk_score': results['risk_score'],
                'risk_level': results['risk_level'],
                'details': results
            }
            app.db.save_scan(scan_data)
            
            # Generate report if requested
            if args.report:
                report_path = app.report_generator.generate_file_report(results)
                if report_path:
                    print(f"{getattr(Colors, 'GREEN', '')}[✓] Report saved to: {report_path}{getattr(Colors, 'RESET', '')}")
            
            # Save output if requested
            if args.output:
                with open(args.output, 'w') as f:
                    json.dump(results, f, indent=2)
                print(f"{getattr(Colors, 'GREEN', '')}[✓] Results saved to: {args.output}{getattr(Colors, 'RESET', '')}")
        
        return
    
    if args.history:
        display_banner()
        history = app.db.get_recent_scans(50)
        
        if not history:
            print(f"{getattr(Colors, 'YELLOW', '')}[!] No scan history found{getattr(Colors, 'RESET', '')}")
        else:
            print(f"\n{getattr(Colors, 'BOLD', '')}RECENT SCANS{getattr(Colors, 'RESET', '')}")
            print(f"{getattr(Colors, 'CYAN', '')}{'='*70}{getattr(Colors, 'RESET', '')}")
            
            for scan in history:
                timestamp = scan['timestamp'][:19] if scan['timestamp'] else 'Unknown'
                color = get_risk_color(scan['risk_score'])
                
                print(f"{timestamp} | {color}{scan['type']:4}{getattr(Colors, 'RESET', '')} | "
                      f"Score: {color}{scan['risk_score']:3}{getattr(Colors, 'RESET', '')} | "
                      f"Level: {color}{scan['risk_level']:10}{getattr(Colors, 'RESET', '')} | "
                      f"Target: {scan['target'][:30]}")
        return
    
    # If no arguments, run interactive mode
    app.run()

